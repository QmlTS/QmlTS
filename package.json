{
  "name": "@qmlts/registry",
  "version": "0.1.0",
  "description": "Qt type registry builder for QmlTS — scans Qt installations and builds a unified type registry from .qmltypes, qmldir, and metatypes JSON files",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "generate": "bun run scripts/generate-registry.ts",
    "generate:dsl": "bun run scripts/generate-dsl.ts",
    "test:prepare": "bun run generate:dsl",
    "pretest": "bun run test:prepare",
    "test": "bun test",
    "pretest:ci": "bun run test:prepare",
    "test:ci": "bun test --bail=1",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "qml",
    "qt",
    "typescript",
    "dsl",
    "code-generation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "^6.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "ts-morph": "^28.0.0"
  }
}

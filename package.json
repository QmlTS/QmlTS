{
  "name": "@qmlts/registry",
  "version": "0.1.0",
  "description": "Qt type registry builder for QmlTS — scans Qt installations and builds a unified type registry from .qmltypes, qmldir, and metatypes JSON files",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "test:ci": "bun test --bail=1",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["qml", "qt", "typescript", "dsl", "code-generation"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8"
  }
}

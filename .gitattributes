# Normalize line endings for all text files in the repository.
* text=auto eol=lf

# Keep Windows command scripts on CRLF when they appear.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets and artifacts must never be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.jar binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.pdb binary
*.a binary
*.lib binary
*.wasm binary
*.bin binary
*.node binary
